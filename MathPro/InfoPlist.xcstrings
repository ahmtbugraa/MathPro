    "NSCameraUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يلزم الوصول إلى الكاميرا لتصوير المسائل الرياضية."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Riyaziyyat məsələlərini şəkilə almaq üçün kameraya giriş lazımdır."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Необходим е достъп до камерата за заснемане на математически задачи."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "গণিতের সমস্যা ছবি তোলার জন্য ক্যামেরা অ্যাক্সেস প্রয়োজন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Cal accés a la càmera per fotografiar problemes matemàtics."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro fotografování matematických úloh je nutný přístup k fotoaparátu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kameraadgang er nødvendig for at fotografere matematikopgaver."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamerazugriff wird benötigt, um Matheaufgaben zu fotografieren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απαιτείται πρόσβαση στην κάμερα για τη λήψη φωτογραφιών μαθηματικών προβλημάτων."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is needed to photograph math problems."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is needed to photograph maths problems."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is needed to photograph math problems."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is needed to photograph maths problems."
          }
        },
        "en-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is needed to photograph maths problems."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita acceso a la cámara para fotografiar problemas matemáticos."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita acceso a la cámara para fotografiar problemas matemáticos."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita acceso a la cámara para fotografiar problemas matemáticos."
          }
        },
        "es-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita acceso a la cámara para fotografiar problemas matemáticos."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای عکس‌برداری از مسائل ریاضی به دسترسی دوربین نیاز است."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kameran käyttöoikeus tarvitaan matemaattisten tehtävien kuvaamiseen."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Kailangan ang access sa camera para makuhanan ng litrato ang mga math problem."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès à la caméra est nécessaire pour photographier les problèmes mathématiques."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès à la caméra est nécessaire pour photographier les problèmes mathématiques."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "ગણિતની સમસ્યાઓનો ફોટો લેવા માટે કેમેરા ઍક્સેસ જરૂરી છે."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana buƙatar samun damar kyamara don ɗaukar hoton matsalolin lissafi."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "נדרשת גישה למצלמה כדי לצלם בעיות מתמטיות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गणित की समस्याओं की फोटो लेने के लिए कैमरा एक्सेस आवश्यक है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pristup kameri potreban je za fotografiranje matematičkih zadataka."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A matematikai feladatok lefényképezéséhez kamera-hozzáférés szükséges."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses kamera diperlukan untuk memotret soal matematika."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso alla fotocamera è necessario per fotografare i problemi di matematica."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "数学の問題を撮影するためにカメラへのアクセスが必要です。"
          }
        },
        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses kamera dibutuhake kanggo motret soal matematika."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Математика есептерін суретке түсіру үшін камераға рұқсат қажет."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಗಣಿತ ಸಮಸ್ಯೆಗಳನ್ನು ಫೋಟೋ ತೆಗೆಯಲು ಕ್ಯಾಮೆರಾ ಪ್ರವೇಶ ಅಗತ್ಯವಿದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수학 문제를 촬영하려면 카메라 접근 권한이 필요합니다."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
