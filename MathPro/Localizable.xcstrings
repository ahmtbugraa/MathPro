        "en-IN" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos you take are sent to our AI service over a secure connection to generate solutions. Images are not stored on any server after processing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las fotos que tomas se envían a nuestro servicio de IA a través de una conexión segura para generar soluciones. Las imágenes no se almacenan en ningún servidor después del procesamiento."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las fotos que tomas se envían a nuestro servicio de IA a través de una conexión segura para generar soluciones. Las imágenes no se almacenan en ningún servidor después del procesamiento."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las fotos que tomas se envían a nuestro servicio de IA a través de una conexión segura para generar soluciones. Las imágenes no se almacenan en ningún servidor después del procesamiento."
          }
        },
        "es-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las fotos que tomas se envían a nuestro servicio de IA a través de una conexión segura para generar soluciones. Las imágenes no se almacenan en ningún servidor después del procesamiento."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عکس‌هایی که می‌گیرید از طریق اتصال امن به سرویس هوش مصنوعی ما ارسال می‌شوند تا راه‌حل تولید شود. تصاویر پس از پردازش در هیچ سروری ذخیره نمی‌شوند."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ottamasi valokuvat lähetetään AI-palveluumme suojatun yhteyden kautta ratkaisujen luomiseksi. Kuvia ei tallenneta millekään palvelimelle käsittelyn jälkeen."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ang mga larawan na kinukuha mo ay ipinapadala sa aming AI service sa pamamagitan ng secure na koneksyon para gumawa ng solusyon. Ang mga larawan ay hindi sine-save sa anumang server pagkatapos ng pagproseso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les photos que vous prenez sont envoyées à notre service d'IA via une connexion sécurisée pour générer des solutions. Les images ne sont stockées sur aucun serveur après le traitement."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les photos que vous prenez sont envoyées à notre service d'IA via une connexion sécurisée pour générer des solutions. Les images ne sont stockées sur aucun serveur après le traitement."
          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "તમે લીધેલા ફોટા ઉકેલો બનાવવા માટે સુરક્ષિત કનેક્શન દ્વારા અમારી AI સેવામાં મોકલવામાં આવે છે. પ્રક્રિયા પછી છબીઓ કોઈપણ સર્વર પર સંગ્રહિત થતી નથી."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ana aika hotunan da kuka ɗauka zuwa sabis ɗinmu na AI ta hanyar haɗin amintacce don samar da mafita. Ba a adana hotuna a kowane uwar garke bayan aiwatarwa."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "תמונות שאתה מצלם נשלחות לשירות ה-AI שלנו דרך חיבור מאובטח ליצירת פתרונות. התמונות אינן נשמרות באף שרת לאחר העיבוד."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके द्वारा ली गई तस्वीरें समाधान बनाने के लिए सुरक्षित कनेक्शन के माध्यम से हमारी AI सेवा को भेजी जाती हैं। प्रसंस्करण के बाद छवियां किसी भी सर्वर पर संग्रहीत नहीं की जातीं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotografije koje snimite šalju se našoj AI usluzi putem sigurne veze radi generiranja rješenja. Slike se ne pohranjuju na nijednom poslužitelju nakon obrade."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az Ön által készített fényképek biztonságos kapcsolaton keresztül kerülnek elküldésre AI szolgáltatásunkhoz a megoldások generálásához. A képek feldolgozás után nem tárolódnak egyetlen szerveren sem."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foto yang Anda ambil dikirim ke layanan AI kami melalui koneksi aman untuk menghasilkan solusi. Gambar tidak disimpan di server mana pun setelah diproses."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le foto scattate vengono inviate al nostro servizio AI tramite connessione sicura per generare soluzioni. Le immagini non vengono archiviate su alcun server dopo l'elaborazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "撮影した写真は、解答を生成するために安全な接続を介してAIサービスに送信されます。画像は処理後、サーバーに保存されません。"
          }
        },
        "jv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foto sing sampeyan jepret dikirim menyang layanan AI kita liwat sambungan aman kanggo nggawe solusi. Gambar ora disimpen ing server sawise diproses."
          }
        },
        "kk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сіз түсірген фотосуреттер шешімдер жасау үшін қауіпсіз байланыс арқылы AI қызметімізге жіберіледі. Суреттер өңдеуден кейін ешбір серверде сақталмайды."
          }
        },
        "kn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ನೀವು ತೆಗೆದ ಫೋಟೋಗಳನ್ನು ಪರಿಹಾರಗಳನ್ನು ರಚಿಸಲು ಸುರಕ್ಷಿತ ಸಂಪರ್ಕದ ಮೂಲಕ ನಮ್ಮ AI ಸೇವೆಗೆ ಕಳುಹಿಸಲಾಗುತ್ತದೆ. ಪ್ರಕ್ರಿಯೆಯ ನಂತರ ಚಿತ್ರಗಳನ್ನು ಯಾವುದೇ ಸರ್ವರ್‌ನಲ್ಲಿ ಸಂಗ್ರಹಿಸಲಾಗುವುದಿಲ್ಲ."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "촬영한 사진은 솔루션을 생성하기 위해 보안 연결을 통해 AI 서비스로 전송됩니다. 이미지는 처리 후 어떤 서버에도 저장되지 않습니다."
          }
        },
        "ku" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wêneyên ku hûn dikişînin bi girêdanek ewle ji bo çêkirina çareseriyê ji karûbarê me yê AI re têne şandin. Wêne piştî pêvajoyê li tu serverekê nayên hilanîn."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तुम्ही काढलेले फोटो उपाय तयार करण्यासाठी सुरक्षित कनेक्शनद्वारे आमच्या AI सेवेला पाठवले जातात. प्रक्रियेनंतर प्रतिमा कोणत्याही सर्व्हरवर साठवल्या जात नाहीत."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foto yang anda ambil dihantar ke perkhidmatan AI kami melalui sambungan selamat untuk menjana penyelesaian. Imej tidak disimpan di mana-mana pelayan selepas pemprosesan."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bilder du tar sendes til vår AI-tjeneste via en sikker tilkobling for å generere løsninger. Bildene lagres ikke på noen server etter behandling."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foto's die u maakt worden via een beveiligde verbinding naar onze AI-dienst gestuurd om oplossingen te genereren. Afbeeldingen worden na verwerking niet op een server opgeslagen."
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ਤੁਹਾਡੀਆਂ ਲਈਆਂ ਤਸਵੀਰਾਂ ਹੱਲ ਬਣਾਉਣ ਲਈ ਸੁਰੱਖਿਅਤ ਕਨੈਕਸ਼ਨ ਰਾਹੀਂ ਸਾਡੀ AI ਸੇਵਾ ਨੂੰ ਭੇਜੀਆਂ ਜਾਂਦੀਆਂ ਹਨ। ਪ੍ਰੋਸੈਸਿੰਗ ਤੋਂ ਬਾਅਦ ਤਸਵੀਰਾਂ ਕਿਸੇ ਵੀ ਸਰਵਰ 'ਤੇ ਸਟੋਰ ਨਹੀਂ ਕੀਤੀਆਂ ਜਾਂਦੀਆਂ।"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zrobione zdjęcia są wysyłane do naszej usługi AI za pośrednictwem bezpiecznego połączenia w celu wygenerowania rozwiązań. Obrazy nie są przechowywane na żadnym serwerze po przetworzeniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As fotos tiradas são enviadas ao nosso serviço de IA por meio de uma conexão segura para gerar soluções. As imagens não são armazenadas em nenhum servidor após o processamento."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As fotos tiradas são enviadas ao nosso serviço de IA através de uma ligação segura para gerar soluções. As imagens não são armazenadas em nenhum servidor após o processamento."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotografiile pe care le faceți sunt trimise serviciului nostru AI printr-o conexiune securizată pentru a genera soluții. Imaginile nu sunt stocate pe niciun server după procesare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сделанные фотографии отправляются в наш AI-сервис через защищённое соединение для генерации решений. Изображения не сохраняются на серверах после обработки."
