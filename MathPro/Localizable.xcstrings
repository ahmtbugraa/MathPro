    "data_disclosure_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم إرسال الصور التي تلتقطها إلى خدمة الذكاء الاصطناعي عبر اتصال آمن لإنشاء الحلول. لا يتم تخزين الصور على أي خادم بعد المعالجة."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çəkdiyiniz şəkillər həll yaratmaq üçün təhlükəsiz bağlantı ilə AI xidmətimizə göndərilir. Şəkillər emal edildikdən sonra heç bir serverdə saxlanılmır."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Снимките, които правите, се изпращат до нашата AI услуга чрез защитена връзка за генериране на решения. Изображенията не се съхраняват на сървър след обработката."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার তোলা ছবিগুলো সমাধান তৈরি করতে নিরাপদ সংযোগের মাধ্যমে আমাদের AI পরিষেবায় পাঠানো হয়। প্রক্রিয়াকরণের পরে ছবিগুলো কোনো সার্ভারে সংরক্ষিত হয় না।"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les fotos que feu s'envien al nostre servei d'IA mitjançant una connexió segura per generar solucions. Les imatges no s'emmagatzemen a cap servidor després del processament."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pořízené fotografie jsou odesílány do naší AI služby přes zabezpečené připojení za účelem generování řešení. Obrázky nejsou po zpracování uchovávány na žádném serveru."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotos du tager sendes til vores AI-tjeneste via en sikker forbindelse for at generere løsninger. Billeder gemmes ikke på nogen server efter behandling."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgenommene Fotos werden über eine sichere Verbindung an unseren KI-Dienst gesendet, um Lösungen zu erstellen. Bilder werden nach der Verarbeitung nicht auf einem Server gespeichert."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι φωτογραφίες που τραβάτε αποστέλλονται στην υπηρεσία AI μας μέσω ασφαλούς σύνδεσης για τη δημιουργία λύσεων. Οι εικόνες δεν αποθηκεύονται σε κανέναν διακομιστή μετά την επεξεργασία."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos you take are sent to our AI service over a secure connection to generate solutions. Images are not stored on any server after processing."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos you take are sent to our AI service over a secure connection to generate solutions. Images are not stored on any server after processing."
          }
        },
        "en-CA" : {
