    "A Premium subscription is required to solve math problems. Subscribe now for unlimited solving." : {
      "comment" : "A message displayed to the user when they try to solve a problem but don't have a premium subscription.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتطلب حل المسائل اشتراكًا مميزًا. اشترك الآن لحل غير محدود."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riyaziyyat məsələlərini həll etmək üçün Premium abunə tələb olunur. Limitsiz həllər üçün indi abunə olun."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необходим е Premium абонамент, за да решавате математически задачи. Абонирайте се сега за неограничен брой решения."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "গণিত প্রবলেম সমাধান করতে একটি প্রিমিয়াম সাবস্ক্রিপশন প্রয়োজন। সীমাহীন সমাধানের জন্য এখনই সাবস্ক্রাইব করুন।"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cal una subscripció Premium per resoldre problemes de matemàtiques. Subscriu‑te ara per resoldre sense límits."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro řešení příkladů je vyžadované předplatné Premium. Předplaťte nyní pro neomezené řešení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der kræves et Premium-abonnement for at løse matematikopgaver. Abonner nu for ubegrænset løsning."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
